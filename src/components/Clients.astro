---
// src/components/Clients.astro
const clients = [
  { name: "Buzca", logo: "/src/assets/images/clients/buzca.png" },
  { name: "Cotecmar", logo: "/src/assets/images/clients/CotecmarLogo.png" },
  { name: "DIAN", logo: "/src/assets/images/clients/dian.png" },
  { name: "MinerosColombia", logo: "/src/assets/images/clients/mineros.png" },
  { name: "NFC", logo: "/src/assets/images/clients/naviera.png" },
  { name: "Presenmar" , logo: "/src/assets/images/clients/presenmar.png" }
];
---

<section id="clientes" class="py-20 bg-white border-t border-slate-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <p class="text-slate-400 font-medium uppercase tracking-[0.2em] text-xs">Empresas que confían en nosotros</p>
    </div>
    
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-8 items-center opacity-70">
      {clients.map((client) => (
        <div class="flex justify-center items-center grayscale hover:grayscale-0 transition-all duration-500 cursor-pointer h-20 p-3">
          <img 
            src={client.logo} 
            alt={client.name} 
            class="max-h-full max-w-full w-full h-full object-contain opacity-60 hover:opacity-100 transition-opacity"
            style="object-fit: contain;"
          />
        </div>
      ))}
    </div>
  </div>
</section>